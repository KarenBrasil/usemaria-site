generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Category {
  id       String    @id @default(cuid())
  name     String
  products Product[]
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Float
  image       String?
  isNew       Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sizes ProductSize[]

  categoryId String?
  category   Category?   @relation(fields: [categoryId], references: [id])
  orderItems OrderItem[]
}

model ProductSize {
  id    String @id @default(cuid())
  size  String // PP, P, M, G, GG
  stock Int    @default(0)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Customer {
  id    String  @id @default(cuid())
  name  String
  email String?
  phone String?
  cpf   String?

  orders Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Order {
  id     String @id @default(cuid())
  status String @default("PENDING") // PENDING, PAID, SHIPPED, DELIVERED, CANCELLED
  total  Float

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])

  items OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrderItem {
  id       String @id @default(cuid())
  quantity Int
  price    Float
  size     String

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
}

model StoreSettings {
  id             String @id @default("default")
  storeName      String @default("USE MARIA")
  hero1Image     String @default("/images/catalog/page-0001.jpg")
  hero1Subtitle  String @default("Lançamento Exclusivo Online")
  hero1Title     String @default("A Coleção Divina")
  hero2Image     String @default("/images/catalog/page-0006.jpg")
  hero2Subtitle  String @default("Escolha da Estilista")
  hero2Title     String @default("O Look Perfeito")
  hero2Text      String @default("Capturado por @fotografo")
  whatsappNumber String @default("5585994277446")
  instagramUrl   String @default("#")
  tiktokUrl      String @default("#")
  
  // PIX Settings
  pixKey         String @default("CNPJ: 00.000.000/0001-00")
  pixName        String @default("USE MARIA OFICIAL")
}
